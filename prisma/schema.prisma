generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  EMPLOYEE
  PROJECT_SUPERVISOR
  MANAGER
}

enum ElementStatus {
  NOT_STARTED
  PENDING_APPROVAL
  APPROVED
  REJECTED
  NOT_APPLICABLE
  RETURNED
}

enum CourseStatus {
  PREPARATION
  EXECUTION
  AWAITING_CLOSURE
  CLOSED
  ARCHIVED
}

enum KpiPeriodType {
  MONTHLY
  QUARTERLY
  YEARLY
}

enum PerformanceLevel {
  OUTSTANDING
  VERY_GOOD
  GOOD
  NEEDS_IMPROVEMENT
  WEAK
}

model OperationalProject {
  id          String   @id @default(uuid())
  name        String   @unique
  createdAt   DateTime @default(now())
  users       User[]
  courses     Course[]
  supervisors ProjectSupervisor[]
}

model User {
  id                   String   @id @default(uuid())
  email                String   @unique
  passwordHash         String
  firstName            String
  lastName             String
  mobileNumber         String
  extensionNumber      String?
  roles                Role[]
  isActive             Boolean  @default(true)
  operationalProjectId String
  operationalProject   OperationalProject @relation(fields: [operationalProjectId], references: [id])
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  termsAccepted        Boolean  @default(false)
  termsAcceptedAt      DateTime?

  primaryCourses       Course[]                @relation("PrimaryResponsible")
  supportingCourses    CourseSupport[]         @relation("SupportingMember")
  auditLogs            AuditLog[]
  notifications        Notification[]
  executedElements     CourseClosureTracking[] @relation("Executor")
  decidedElements      CourseClosureTracking[] @relation("Decider")

  sentMessages         Message[]               @relation("MessageSender")
  receivedMessages     MessageRecipient[]      @relation("MessageRecipientUser")
  readMessages         MessageRecipient[]      @relation("MessageReadBy")

  kpiSnapshots         EmployeeKpiSnapshot[]   @relation("KpiSnapshotUser")
  kpiNotes             EmployeeKpiNote[]       @relation("KpiNoteUser")
  managerKpiNotes      EmployeeKpiNote[]       @relation("KpiNoteManager")

  courseAssignments    CourseAssignmentRegister[] @relation("AssignmentUser")

  // ----- علاقة الإشراف على مشاريع تشغيلية -----
  // مشرف المشروع مرتبط بمشروع واحد أو أكثر عبر هذا الجدول
  supervisedProjects   ProjectSupervisor[]        @relation("SupervisorUser")
}

// =============================================================
// جدول الإشراف على المشاريع التشغيلية
// -------------------------------------------------------------
// يربط مستخدماً يحمل دور PROJECT_SUPERVISOR بمشروع تشغيلي واحد
// القاعدة: كل مشرف لمشروع واحد فقط (فرض عبر الفهرس الفريد على userId)
// =============================================================
model ProjectSupervisor {
  id                   String   @id @default(uuid())
  userId               String
  operationalProjectId String
  createdAt            DateTime @default(now())
  createdById          String?  // المدير الذي أسند

  user                 User               @relation("SupervisorUser", fields: [userId], references: [id], onDelete: Cascade)
  operationalProject   OperationalProject @relation(fields: [operationalProjectId], references: [id], onDelete: Cascade)

  // مشرف واحد لكل مستخدم (لا يمكن أن يشرف على أكثر من مشروع)
  @@unique([userId])
  @@index([operationalProjectId])
}

model Course {
  id                             String       @id @default(uuid())
  name                           String
  code                           String?
  beneficiaryEntity              String?
  city                           String
  locationType                   String
  startDate                      DateTime
  endDate                        DateTime
  numTrainees                    Int
  courseType                     String
  requiresAdvance                Boolean      @default(false)
  requiresRevenue                Boolean      @default(false)
  materialsIssued                Boolean      @default(false)
  requiresAdvanceSettlement      Boolean      @default(false)
  requiresSupervisorCompensation Boolean      @default(false)
  requiresTrainerCompensation    Boolean      @default(false)
  status                         CourseStatus @default(PREPARATION)

  operationalProjectId           String
  operationalProject             OperationalProject @relation(fields: [operationalProjectId], references: [id])

  primaryEmployeeId              String
  primaryEmployee                User @relation("PrimaryResponsible", fields: [primaryEmployeeId], references: [id])

  supportingTeam                 CourseSupport[]
  closureElements                CourseClosureTracking[]
  auditLogs                      AuditLog[]
  messages                       Message[]

  createdAt                      DateTime @default(now())
  updatedAt                      DateTime @updatedAt
}

model CourseSupport {
  id       String @id @default(uuid())
  courseId String
  userId   String
  course   Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
  user     User   @relation("SupportingMember", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([courseId, userId])
}

model ClosureElement {
  id                     String @id @default(uuid())
  key                    String @unique
  name                   String
  isFormBased            Boolean @default(false)
  courseClosureTrackings CourseClosureTracking[]
}

model CourseClosureTracking {
  id              String @id @default(uuid())
  courseId        String
  elementId       String
  status          ElementStatus @default(NOT_STARTED)

  executionAt     DateTime?
  executedById    String?
  executor        User? @relation("Executor", fields: [executedById], references: [id])

  decisionAt      DateTime?
  decidedById     String?
  decider         User? @relation("Decider", fields: [decidedById], references: [id])

  rejectionReason String?
  notes           String?
  formData        Json?

  course          Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
  element         ClosureElement @relation(fields: [elementId], references: [id])

  @@unique([courseId, elementId])
}

model AuditLog {
  id          String @id @default(uuid())
  courseId    String?
  course      Course? @relation(fields: [courseId], references: [id])
  userId      String
  user        User   @relation(fields: [userId], references: [id])
  roleContext String
  action      String
  details     Json?
  createdAt   DateTime @default(now())
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  type      String
  title     String
  message   String
  isRead    Boolean  @default(false)
  metadata  Json?
  createdAt DateTime @default(now())

  user      User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Message {
  id          String             @id @default(uuid())
  senderId    String
  subject     String
  body        String
  courseId    String?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  sender      User               @relation("MessageSender", fields: [senderId], references: [id], onDelete: Cascade)
  course      Course?            @relation(fields: [courseId], references: [id], onDelete: SetNull)
  recipients  MessageRecipient[]
}

model MessageRecipient {
  id            String    @id @default(uuid())
  messageId     String
  recipientId   String
  isRead        Boolean   @default(false)
  readAt        DateTime?
  readById      String?
  createdAt     DateTime  @default(now())

  message       Message   @relation(fields: [messageId], references: [id], onDelete: Cascade)
  recipient     User      @relation("MessageRecipientUser", fields: [recipientId], references: [id], onDelete: Cascade)
  readBy        User?     @relation("MessageReadBy", fields: [readById], references: [id], onDelete: SetNull)

  @@unique([messageId, recipientId])
}

model CourseAssignmentRegister {
  id                    String        @id @default(uuid())
  userId                String
  user                  User          @relation("AssignmentUser", fields: [userId], references: [id], onDelete: Cascade)

  periodType            KpiPeriodType @default(MONTHLY)
  periodLabel           String
  periodStart           DateTime
  periodEnd             DateTime

  assignedCoursesCount  Int           @default(0)
  notes                 String?

  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  @@unique([userId, periodType, periodLabel])
  @@index([periodType, periodStart, periodEnd])
}

model EmployeeKpiSetting {
  id                           String   @id @default(uuid())
  name                         String   @default("Default KPI Settings")
  isActive                     Boolean  @default(true)

  closureCompletionWeight      Float    @default(15)
  overdueClosuresWeight        Float    @default(15)

  avgElementSubmissionWeight   Float    @default(5)
  avgResubmissionWeight        Float    @default(5)
  avgCourseClosureWeight       Float    @default(10)

  firstPassApprovalWeight      Float    @default(15)
  returnRateWeight             Float    @default(10)
  rejectRateWeight             Float    @default(5)
  errorRateWeight              Float    @default(5)

  overdueCoursesWeight         Float    @default(5)
  overdueElementsWeight        Float    @default(5)
  staleElementsWeight          Float    @default(5)

  createdAt                    DateTime @default(now())
  updatedAt                    DateTime @updatedAt

  snapshots                    EmployeeKpiSnapshot[]
}

model EmployeeKpiSnapshot {
  id                               String              @id @default(uuid())
  userId                           String
  periodType                       KpiPeriodType
  periodLabel                      String
  periodStart                      DateTime
  periodEnd                        DateTime

  requiredElementsCount            Int                 @default(0)
  completedElementsCount           Int                 @default(0)
  closureCompletionRate            Float               @default(0)

  dueCoursesCount                  Int                 @default(0)
  closedCoursesCount               Int                 @default(0)
  dueCourseClosureRate             Float               @default(0)

  submittedElementsCount           Int                 @default(0)
  approvedElementsCount            Int                 @default(0)
  returnedElementsCount            Int                 @default(0)
  rejectedElementsCount            Int                 @default(0)

  firstPassApprovalRate            Float               @default(0)
  returnRate                       Float               @default(0)
  rejectRate                       Float               @default(0)
  operationalErrorRate             Float               @default(0)

  avgElementSubmissionHours        Float               @default(0)
  avgResubmissionHours             Float               @default(0)
  avgCourseClosureDelayDays        Float               @default(0)

  overdueCoursesCount              Int                 @default(0)
  overdueCoursesRate               Float               @default(0)

  overdueElementsCount             Int                 @default(0)
  overdueElementsRate              Float               @default(0)

  stalePendingElementsCount        Int                 @default(0)
  stalePendingElementsRate         Float               @default(0)

  productivityScore                Float               @default(0)
  speedScore                       Float               @default(0)
  qualityScore                     Float               @default(0)
  disciplineScore                  Float               @default(0)
  finalScore                       Float               @default(0)
  performanceLevel                 PerformanceLevel    @default(GOOD)

  settingsId                       String?
  settings                         EmployeeKpiSetting? @relation(fields: [settingsId], references: [id], onDelete: SetNull)

  createdAt                        DateTime            @default(now())
  updatedAt                        DateTime            @updatedAt

  user                             User                @relation("KpiSnapshotUser", fields: [userId], references: [id], onDelete: Cascade)
  notes                            EmployeeKpiNote[]

  @@unique([userId, periodType, periodLabel])
  @@index([periodType, periodStart, periodEnd])
  @@index([finalScore])
}

model EmployeeKpiNote {
  id          String              @id @default(uuid())
  snapshotId  String
  userId      String
  managerId   String
  note        String
  createdAt   DateTime            @default(now())

  snapshot    EmployeeKpiSnapshot @relation(fields: [snapshotId], references: [id], onDelete: Cascade)
  user        User                @relation("KpiNoteUser", fields: [userId], references: [id], onDelete: Cascade)
  manager     User                @relation("KpiNoteManager", fields: [managerId], references: [id], onDelete: Cascade)

  @@index([snapshotId])
  @@index([userId])
  @@index([managerId])
}
// =============================================================
// نظام المهام المجدولة المرن
// -------------------------------------------------------------
// جدول مهام يُشغّل بواسطة مسار كرون واحد (يستيقظ يومياً)
// يدعم عدداً غير محدود من المهام المجدولة بترددات متنوعة
// =============================================================

enum ScheduledJobType {
  COURSE_DELAY_CHECK      // فحص الدورات المتأخرة في الإقفال
  ELEMENT_STALE_CHECK     // فحص العناصر الراكدة
  KPI_AUTO_SNAPSHOT       // التقاط لقطة KPI دورية
  CUSTOM                  // مهمة مخصصة
}

enum ScheduledJobStatus {
  ACTIVE
  PAUSED
  COMPLETED
  FAILED
}

model ScheduledJob {
  id              String             @id @default(uuid())
  name            String             // اسم وصفي
  type            ScheduledJobType
  status          ScheduledJobStatus @default(ACTIVE)

  // التكرار: كل كم ساعة تُشغّل هذه المهمة
  intervalHours   Int                @default(24)

  // بيانات اختيارية يحتاجها نوع المهمة (مثلاً: معرف المشروع)
  payload         Json?

  // التتبع
  lastRunAt       DateTime?
  nextRunAt       DateTime
  lastResult      Json?
  lastError       String?
  runCount        Int                @default(0)

  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  @@index([status, nextRunAt])
  @@index([type])
}
