# ================================================================
# ملف بيئة المشروع الموحد
# ----------------------------------------------------------------
# للتطوير المحلي: انسخ هذا الملف إلى .env وعدّل القيم
#
# على فرسيل: أضف هذه المتغيرات في إعدادات المشروع:
#   Project Settings → Environment Variables
# ================================================================

# ----------------------------------------------------------------
# قاعدة البيانات (سوبابيس بوستجرس)
# ----------------------------------------------------------------
# رابط الاستخدام اليومي (مع pgbouncer للأداء)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:6543/postgres?pgbouncer=true"

# رابط مباشر للترحيلات (بدون pgbouncer)
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/postgres"

# ----------------------------------------------------------------
# المصادقة
# ----------------------------------------------------------------
# مفتاح سري طويل عشوائي لتوقيع الرموز
# مثال: استخدم openssl rand -base64 32 لتوليده
JWT_SECRET="change_this_to_a_long_random_string_min_32_chars"

# ----------------------------------------------------------------
# المهام المجدولة (الكرون)
# ----------------------------------------------------------------
# سر يحمي مسار /api/cron/run من الاستدعاء المباشر
# فرسيل يضبطه تلقائياً في الإنتاج
CRON_SECRET="change_this_to_a_cron_secret"

# ----------------------------------------------------------------
# بيئة التشغيل
# ----------------------------------------------------------------
NODE_ENV=development
